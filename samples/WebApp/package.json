    "@iyulab/chat-components": "^0.5.1",
    "@iyulab/http-client": "^0.8.1",
    "@lit-labs/router": "^0.1.4",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  }
